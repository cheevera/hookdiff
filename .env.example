# Django
DATABASE_URL=postgres://hookdiff:hookdiff@postgres:5432/hookdiff
REDIS_URL=redis://redis:6379/0
DJANGO_SECRET_KEY=dev-insecure-key-do-not-use-in-production
DJANGO_DEBUG=1
