# Documentation only. Copy to .env and fill in as needed.
# The frontend currently has no env vars.
# The variables below are placeholders for Phase 2 (Django backend, Postgres, Redis).

# Postgres
# POSTGRES_DB=hookdiff
# POSTGRES_USER=hookdiff
# POSTGRES_PASSWORD=

# Django
# DATABASE_URL=postgres://hookdiff:@postgres:5432/hookdiff
# REDIS_URL=redis://redis:6379/0
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=1
